# API Configuration
API_PORT=3000
API_HOST=localhost

# Database
DATABASE_PATH=./cache.db

# Embedding Provider Configuration (Phase 2 Step 1)
# Choose: 'local' (FREE, privacy-first) or 'openai' (higher quality)
EMBEDDING_PROVIDER=local

# OpenAI Configuration (only needed if EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-small

# Local Model Configuration (only used if EMBEDDING_PROVIDER=local)
# Options: 'all-MiniLM-L6-v2' (default, fast), 'all-mpnet-base-v2' (slower, better), 'e5-small-v2' (multilingual)
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Cache Configuration
SIMILARITY_THRESHOLD=0.85
MAX_CACHE_SIZE=1000

# Embedding Cache (Phase 1 Step 1 Optimization)
# LRU cache size for reusing embeddings - reduces API calls by 30-40%
EMBEDDING_CACHE_SIZE=500

# Exact Match Cache (Phase 1 Step 2 Optimization)
# LRU cache size for instant exact string lookups - zero cost for repeated queries
EXACT_MATCH_CACHE_SIZE=1000

# Vector Quantization (Phase 1 Step 3 Optimization)
# Enable quantization for 75% storage reduction with <1% accuracy impact
# Set to 'false' to disable (default: true)
ENABLE_QUANTIZATION=true

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Web App
VITE_API_URL=http://localhost:3000
