# API Configuration
API_PORT=3000
API_HOST=localhost

# Database
DATABASE_PATH=./cache.db

# Embeddings API (e.g., OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-small

# Cache Configuration
SIMILARITY_THRESHOLD=0.85
MAX_CACHE_SIZE=1000

# Embedding Cache (Phase 1 Step 1 Optimization)
# LRU cache size for reusing embeddings - reduces API calls by 30-40%
EMBEDDING_CACHE_SIZE=500

# Exact Match Cache (Phase 1 Step 2 Optimization)
# LRU cache size for instant exact string lookups - zero cost for repeated queries
EXACT_MATCH_CACHE_SIZE=1000

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Web App
VITE_API_URL=http://localhost:3000
