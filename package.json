{
  "name": "distributed-semantic-cache-poc",
  "version": "1.0.0",
  "description": "The LLM-call semantic cache layer of the Pomerene stack — caches Query → Response to cut LLM API costs.",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter \"./packages/*\" dev",
    "build": "pnpm --recursive --filter \"./packages/*\" build",
    "clean": "pnpm --recursive --filter \"./packages/*\" clean",
    "type-check": "pnpm --recursive --filter \"./packages/*\" type-check",
    "test": "pnpm --recursive --filter \"./packages/*\" test",
    "test:watch": "pnpm --parallel --filter \"./packages/*\" test:watch",
    "test:coverage": "pnpm --recursive --filter \"./packages/*\" test:coverage"
  },
  "keywords": [
    "semantic-cache",
    "embeddings",
    "distributed",
    "pomerene",
    "llm-cache",
    "agentic"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
