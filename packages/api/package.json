{
  "name": "@distributed-semantic-cache/api",
  "version": "1.0.0",
  "description": "API server with Fastify, SQLite, and embeddings",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "benchmark": "tsx benchmarks/comprehensive-benchmark.ts",
    "benchmark:scale": "tsx benchmarks/scale-benchmark.ts",
    "benchmark:competitor": "tsx benchmarks/competitor-comparison.ts",
    "benchmark:gptcache": "tsx benchmarks/gptcache-comparison.ts",
    "benchmark:cost": "tsx benchmarks/cost-calculator.ts"
  },
  "dependencies": {
    "@distributed-semantic-cache/shared": "workspace:*",
    "@fastify/cors": "^8.5.0",
    "@fastify/rate-limit": "^10.3.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^9.6.0",
    "dotenv": "^16.6.1",
    "fastify": "^4.29.1",
    "openai": "^4.104.0",
    "parquetjs-lite": "^0.8.7",
    "pino-pretty": "^9.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.19.26",
    "@vitest/coverage-v8": "^1.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.0.4"
  }
}
