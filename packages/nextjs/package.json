{
  "name": "@distributed-semantic-cache/nextjs",
  "version": "1.0.0",
  "description": "Next.js integration for Distributed Semantic Cache - server actions, route handlers, and React hooks for App Router",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "semantic-cache",
    "nextjs",
    "next",
    "react",
    "server-actions",
    "app-router",
    "llm",
    "ai",
    "caching",
    "openai",
    "anthropic"
  ],
  "author": "Kyle Ma",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kylemaa/distributed-semantic-cache-poc.git",
    "directory": "packages/nextjs"
  },
  "bugs": {
    "url": "https://github.com/kylemaa/distributed-semantic-cache-poc/issues"
  },
  "homepage": "https://github.com/kylemaa/distributed-semantic-cache-poc/tree/main/packages/nextjs#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@distributed-semantic-cache/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "next": ">=13.4.0",
    "react": ">=18.0.0"
  }
}
